{
  "manifest_version": 3,
  "name": "커넥트 스튜디오",
  "short_name": "Connect Studio",
  "version": "1.0.0",
  "description": "숏폼 바이럴 마케팅 광고주 캠페인 관리 플랫폼",
  "action": {
    "default_title": "커넥트 스튜디오 열기"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "https://api.emailjs.com/*",
    "https://www.googleapis.com/*",
    "https://api.anthropic.com/*"
  ]
}
